<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="terraformv" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="DebugWindows">
				<Option output="bin/Debug/terraformVenus" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-fPIC" />
					<Add option="-O0" />
					<Add option="-ggdb3" />
					<Add option="-DCLUIGE_DEBUG" />
					<Add option="-DPDC_DLL_BUILD" />
				</Compiler>
				<Linker>
					<Add option="-static-libgcc" />
					<Add library="../cluige/bin/Debug/libcluige.a" />
				</Linker>
				<ExtraCommands>
					<Add after='cmd /C &quot;xcopy /V /Y /F /D ..\PDCurses\wincon\myDebug\pdcurses.dll  bin\Debug\&quot;' />
					<Add after='cmd /C &quot;xcopy /V /Y /F /D ..\cluige\bin\Debug\cluige.dll  bin\Debug\&quot;' />
				</ExtraCommands>
			</Target>
			<Target title="DebugLinux">
